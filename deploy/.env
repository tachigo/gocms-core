# ============================================================
# GoCMS v2.0 环境变量模板
#
# 用法:
#   1. 复制此文件为 .env.local 并填入实际值
#   2. 启动: docker compose --env-file .env.local up -d
# ============================================================

# ---------- 镜像版本 ----------
GOCMS_VERSION=2.0.0

# ---------- 服务端口 ----------
HTTP_PORT=80
HTTPS_PORT=443

# ---------- 数据库配置 ----------
# SQLite 数据库文件路径（容器内路径，相对 /app）
GOCMS_DB_PATH=data/gocms.db

# ---------- JWT 配置 ----------
# ⚠️ 生产环境必须修改！
GOCMS_JWT_SECRET=your-256-bit-secret-key-change-me

# ---------- 服务端口（容器内）----------
GOCMS_SERVER_PORT=8080

# ---------- 域名配置 ----------
DOMAIN=pre-demo.gocms.tachigo.com

# ---------- 备份配置 ----------
# 备份保留天数
BACKUP_RETAIN_DAYS=7
